# Copy this file to namoo-jmapi/.env.local and fill in local-only secrets.
# Never commit .env.local.

# VPS deployment (default):
JMAPI_BASE_URL=https://jmapi.namooca.com
JMAPI_KEY=replace_with_gateway_key

# Local service (uncomment if running locally):
# JMAPI_BASE_URL=http://localhost:5100
# JMAPI_KEY=

# One or more Jimeng/Dreamina session IDs.
# Prefix international tokens with us-, hk-, jp-, or sg-.
# Multiple tokens are comma-separated and will be selected by available credit.
JIMENG_SESSION_ID=token1,token2
